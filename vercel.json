{
  "buildCommand": "npm run build",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://*.myshopify.com https://admin.shopify.com;"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|build/|favicon.ico).*)",
      "destination": "/api/index.js"
    }
  ]
} 