{
    "buildCommand": "npm run build",
    "outputDirectory": "build/client",
    "functions": {
      "server.js": {
        "runtime": "@vercel/node@3.2.22",
        "includeFiles": "build/**"
      }
    },
    "rewrites": [
      {
        "source": "/(.*)",
        "destination": "/server.js"
      }
    ]
  }